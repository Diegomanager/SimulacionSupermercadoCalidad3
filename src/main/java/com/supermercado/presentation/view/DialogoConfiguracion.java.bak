package com.supermercado.presentation.view;

import com.supermercado.application.dto.ConfiguracionDTO;
import com.supermercado.infrastructure.repository.ConfiguracionRepositorioImpl;
import com.supermercado.infrastructure.config.AppConfig;

import javax.swing.*;
import javax.swing.border.*;
import java.awt.*;

public class DialogoConfiguracion extends JDialog {
    private static final long serialVersionUID = 1L;

    private JSpinner spinnerHorasSimuladas;
    private JSpinner spinnerCajasNormales;
    private JSpinner spinnerCajasRapidas;
    private JSpinner spinnerProbabilidad;
    private JSpinner spinnerLimiteClientes;
    private JSpinner spinnerTiempoNormalMin;
    private JSpinner spinnerTiempoNormalMax;
    private JSpinner spinnerTiempoRapidaMin;
    private JSpinner spinnerTiempoRapidaMax;
    private JSpinner spinnerArticulosMin;
    private JSpinner spinnerArticulosMax;
    private JSpinner spinnerDuracionReal;

    private boolean confirmado = false;
    private ConfiguracionDTO configuracion;

    private static final Color COLOR_BG = new Color(236, 240, 241);
    private static final Color COLOR_WHITE = Color.WHITE;
    private static final Color COLOR_TEXT_DARK = new Color(44, 62, 80);
    private static final Color COLOR_BORDER = new Color(189, 195, 199);
    private static final Color COLOR_BTN_CANCEL = new Color(52, 73, 94);
    private static final Color COLOR_BTN_START = new Color(46, 204, 113);
    private static final Color COLOR_BTN_START_HOVER = new Color(39, 174, 96);

    public DialogoConfiguracion(JFrame parent, ConfiguracionDTO config) {
        super(parent, "Configuracion del Simulador", true);
        
        // PRIMERO: Intentar cargar configuración guardada
        ConfiguracionDTO cargada = null;
        try {
            ConfiguracionRepositorioImpl repo = new ConfiguracionRepositorioImpl(
                AppConfig.getInstance().getLogService()
            );
            cargada = repo.cargar();
            System.out.println("📂 Configuración cargada del archivo");
        } catch (Exception e) {
            System.out.println("⚠️ No se pudo cargar configuración: " + e.getMessage());
        }
        
        // USAR la configuración cargada o la que vino por parámetro
        if (cargada != null && cargada.getHorasSimuladas() > 0) {
            this.configuracion = cargada;
        } else if (config != null) {
            this.configuracion = config;
        } else {
            this.configuracion = new ConfiguracionDTO.Builder().build();
        }
        
        initUI();
        cargarValoresEnSpinners();
    }

    private void cargarValoresEnSpinners() {
        if (configuracion != null) {
            spinnerHorasSimuladas.setValue(configuracion.getHorasSimuladas());
            spinnerDuracionReal.setValue(configuracion.getDuracionRealSegundos());
            spinnerCajasNormales.setValue(configuracion.getNumCajasNormales());
            spinnerCajasRapidas.setValue(configuracion.getNumCajasRapidas());
            spinnerProbabilidad.setValue(configuracion.getProbabilidadLlegadaCliente());
            spinnerLimiteClientes.setValue(configuracion.getLimiteClientes());
            spinnerTiempoNormalMin.setValue(configuracion.getTiempoCajaNormalMin());
            spinnerTiempoNormalMax.setValue(configuracion.getTiempoCajaNormalMax());
            spinnerTiempoRapidaMin.setValue(configuracion.getTiempoCajaRapidaMin());
            spinnerTiempoRapidaMax.setValue(configuracion.getTiempoCajaRapidaMax());
            spinnerArticulosMin.setValue(configuracion.getArticulosClienteMin());
            spinnerArticulosMax.setValue(configuracion.getArticulosClienteMax());
        }
    }

    private void initUI() {
        setLayout(new BorderLayout(0, 0));
        getContentPane().setBackground(COLOR_BG);

        JPanel panelTitulo = new JPanel(new BorderLayout());
        panelTitulo.setBackground(new Color(26, 82, 118));
        panelTitulo.setBorder(BorderFactory.createEmptyBorder(15, 25, 15, 25));

        JLabel titulo = new JLabel("Configuracion del Simulador de Supermercado");
        titulo.setFont(new Font("Segoe UI", Font.BOLD, 18));
        titulo.setForeground(COLOR_WHITE);
        panelTitulo.add(titulo, BorderLayout.WEST);
        add(panelTitulo, BorderLayout.NORTH);

        JPanel panelGeneral = new JPanel();
        panelGeneral.setLayout(new BoxLayout(panelGeneral, BoxLayout.Y_AXIS));
        panelGeneral.setBackground(COLOR_BG);
        panelGeneral.setBorder(BorderFactory.createEmptyBorder(10, 25, 10, 25));

        panelGeneral.add(crearSeccion("1. Tiempo de Simulacion", crearPanelTiempo()));
        panelGeneral.add(Box.createVerticalStrut(8));
        panelGeneral.add(crearSeccion("2. Cajas Registradoras", crearPanelCajas()));
        panelGeneral.add(Box.createVerticalStrut(8));
        panelGeneral.add(crearSeccion("3. Flujo de Clientes", crearPanelClientes()));
        panelGeneral.add(Box.createVerticalStrut(8));
        panelGeneral.add(crearSeccion("4. Tiempos de Atencion", crearPanelTiempos()));
        panelGeneral.add(Box.createVerticalStrut(8));
        panelGeneral.add(crearSeccion("5. Articulos por Cliente", crearPanelArticulos()));

        JScrollPane scrollPane = new JScrollPane(panelGeneral);
        scrollPane.setBorder(null);
        scrollPane.getViewport().setBackground(COLOR_BG);
        scrollPane.setPreferredSize(new Dimension(700, 380));
        scrollPane.getVerticalScrollBar().setUnitIncrement(12);
        add(scrollPane, BorderLayout.CENTER);

        // Panel de botones
        JPanel panelBotones = new JPanel(new FlowLayout(FlowLayout.RIGHT, 15, 12));
        panelBotones.setBackground(COLOR_BG);
        panelBotones.setBorder(BorderFactory.createMatteBorder(1, 0, 0, 0, COLOR_BORDER));

        JButton btnCancelar = new JButton(" Cancelar ");
        btnCancelar.setBackground(COLOR_BTN_CANCEL);
        btnCancelar.setForeground(COLOR_WHITE);
        btnCancelar.setFont(new Font("Segoe UI", Font.BOLD, 13));
        btnCancelar.setOpaque(true);
        btnCancelar.setBorder(BorderFactory.createLineBorder(new Color(40, 55, 70), 1));
        btnCancelar.setContentAreaFilled(true);
        btnCancelar.setFocusPainted(false);
        btnCancelar.setCursor(new Cursor(Cursor.HAND_CURSOR));
        btnCancelar.addActionListener(e -> dispose());

        JButton btnAceptar = new JButton(" Iniciar Simulacion ");
        btnAceptar.setBackground(COLOR_BTN_START);
        btnAceptar.setForeground(COLOR_WHITE);
        btnAceptar.setFont(new Font("Segoe UI", Font.BOLD, 14));
        btnAceptar.setOpaque(true);
        btnAceptar.setBorder(BorderFactory.createLineBorder(new Color(30, 132, 73), 1));
        btnAceptar.setContentAreaFilled(true);
        btnAceptar.setFocusPainted(false);
        btnAceptar.setCursor(new Cursor(Cursor.HAND_CURSOR));
        btnAceptar.addActionListener(e -> {
            if (validarCampos()) {
                guardarConfiguracion();
                // GUARDAR EN ARCHIVO
                try {
                    ConfiguracionRepositorioImpl repo = new ConfiguracionRepositorioImpl(
                        AppConfig.getInstance().getLogService()
                    );
                    repo.guardar(this.configuracion);
                    System.out.println("✅ Configuracion guardada correctamente");
                } catch (Exception ex) {
                    System.err.println("❌ Error al guardar: " + ex.getMessage());
                }
                confirmado = true;
                dispose();
            }
        });

        btnAceptar.addMouseListener(new java.awt.event.MouseAdapter() {
            public void mouseEntered(java.awt.event.MouseEvent evt) {
                btnAceptar.setBackground(COLOR_BTN_START_HOVER);
            }
            public void mouseExited(java.awt.event.MouseEvent evt) {
                btnAceptar.setBackground(COLOR_BTN_START);
            }
        });

        panelBotones.add(btnCancelar);
        panelBotones.add(btnAceptar);
        add(panelBotones, BorderLayout.SOUTH);

        setSize(780, 600);
        setMinimumSize(new Dimension(720, 520));
        setLocationRelativeTo(getParent());
        setResizable(true);
    }

    private JPanel crearSeccion(String titulo, JPanel contenido) {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBackground(COLOR_BG);

        TitledBorder border = BorderFactory.createTitledBorder(
            BorderFactory.createLineBorder(COLOR_BORDER, 1),
            titulo,
            TitledBorder.LEFT,
            TitledBorder.TOP,
            new Font("Segoe UI", Font.BOLD, 12),
            COLOR_TEXT_DARK
        );
        panel.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createEmptyBorder(2, 0, 2, 0),
            border
        ));

        contenido.setBackground(COLOR_BG);
        panel.add(contenido, BorderLayout.CENTER);
        return panel;
    }

    private JPanel crearPanelTiempo() {
        JPanel panel = new JPanel(new FlowLayout(FlowLayout.LEFT, 15, 5));
        spinnerHorasSimuladas = crearSpinner(10, 1, 24, 1);
        spinnerDuracionReal = crearSpinner(30, 5, 300, 5);
        panel.add(new JLabel("Horas simuladas:"));
        panel.add(spinnerHorasSimuladas);
        panel.add(new JLabel("  Duracion real (seg):"));
        panel.add(spinnerDuracionReal);
        return panel;
    }

    private JPanel crearPanelCajas() {
        JPanel panel = new JPanel(new FlowLayout(FlowLayout.LEFT, 15, 5));
        spinnerCajasNormales = crearSpinner(6, 1, 20, 1);
        spinnerCajasRapidas = crearSpinner(2, 0, 10, 1);
        panel.add(new JLabel("Normales:"));
        panel.add(spinnerCajasNormales);
        panel.add(new JLabel("  Rapidas:"));
        panel.add(spinnerCajasRapidas);
        return panel;
    }

    private JPanel crearPanelClientes() {
        JPanel panel = new JPanel(new FlowLayout(FlowLayout.LEFT, 15, 5));
        spinnerProbabilidad = crearSpinner(50, 1, 100, 5);
        spinnerLimiteClientes = crearSpinner(0, 0, 5000, 10);
        panel.add(new JLabel("Probabilidad (%):"));
        panel.add(spinnerProbabilidad);
        panel.add(new JLabel("  Max. clientes:"));
        panel.add(spinnerLimiteClientes);
        return panel;
    }

    private JPanel crearPanelTiempos() {
        JPanel panel = new JPanel(new FlowLayout(FlowLayout.LEFT, 10, 5));
        spinnerTiempoNormalMin = crearSpinner(2, 1, 30, 1);
        spinnerTiempoNormalMax = crearSpinner(8, 1, 60, 1);
        spinnerTiempoRapidaMin = crearSpinner(1, 1, 15, 1);
        spinnerTiempoRapidaMax = crearSpinner(5, 1, 30, 1);
        panel.add(new JLabel("Normal min:"));
        panel.add(spinnerTiempoNormalMin);
        panel.add(new JLabel(" max:"));
        panel.add(spinnerTiempoNormalMax);
        panel.add(new JLabel("  Rapida min:"));
        panel.add(spinnerTiempoRapidaMin);
        panel.add(new JLabel(" max:"));
        panel.add(spinnerTiempoRapidaMax);
        return panel;
    }

    private JPanel crearPanelArticulos() {
        JPanel panel = new JPanel(new FlowLayout(FlowLayout.LEFT, 15, 5));
        spinnerArticulosMin = crearSpinner(1, 1, 20, 1);
        spinnerArticulosMax = crearSpinner(20, 1, 200, 1);
        panel.add(new JLabel("Minimo:"));
        panel.add(spinnerArticulosMin);
        panel.add(new JLabel("  Maximo:"));
        panel.add(spinnerArticulosMax);
        return panel;
    }

    private JSpinner crearSpinner(int valor, int min, int max, int step) {
        int v = Math.max(min, Math.min(max, valor));
        JSpinner spinner = new JSpinner(new SpinnerNumberModel(v, min, max, step));
        spinner.setFont(new Font("Segoe UI", Font.PLAIN, 12));
        return spinner;
    }

    private boolean validarCampos() {
        int tNMin = (Integer) spinnerTiempoNormalMin.getValue();
        int tNMax = (Integer) spinnerTiempoNormalMax.getValue();
        int tRMin = (Integer) spinnerTiempoRapidaMin.getValue();
        int tRMax = (Integer) spinnerTiempoRapidaMax.getValue();
        int aMin = (Integer) spinnerArticulosMin.getValue();
        int aMax = (Integer) spinnerArticulosMax.getValue();

        if (tNMin > tNMax) {
            JOptionPane.showMessageDialog(this, "Tiempo minimo de caja normal no puede ser mayor al maximo.",
                "Error", JOptionPane.ERROR_MESSAGE);
            return false;
        }
        if (tRMin > tRMax) {
            JOptionPane.showMessageDialog(this, "Tiempo minimo de caja rapida no puede ser mayor al maximo.",
                "Error", JOptionPane.ERROR_MESSAGE);
            return false;
        }
        if (aMin > aMax) {
            JOptionPane.showMessageDialog(this, "Articulos minimos no pueden superar a los maximos.",
                "Error", JOptionPane.ERROR_MESSAGE);
            return false;
        }
        return true;
    }

    private void guardarConfiguracion() {
        this.configuracion = new ConfiguracionDTO.Builder()
            .horasSimuladas((Integer) spinnerHorasSimuladas.getValue())
            .duracionRealSegundos((Integer) spinnerDuracionReal.getValue())
            .numCajasNormales((Integer) spinnerCajasNormales.getValue())
            .numCajasRapidas((Integer) spinnerCajasRapidas.getValue())
            .probabilidadLlegadaCliente((Integer) spinnerProbabilidad.getValue())
            .limiteClientes((Integer) spinnerLimiteClientes.getValue())
            .tiempoCajaNormalMin((Integer) spinnerTiempoNormalMin.getValue())
            .tiempoCajaNormalMax((Integer) spinnerTiempoNormalMax.getValue())
            .tiempoCajaRapidaMin((Integer) spinnerTiempoRapidaMin.getValue())
            .tiempoCajaRapidaMax((Integer) spinnerTiempoRapidaMax.getValue())
            .articulosClienteMin((Integer) spinnerArticulosMin.getValue())
            .articulosClienteMax((Integer) spinnerArticulosMax.getValue())
            .build();
    }

    public boolean isConfirmado() { return confirmado; }
    public ConfiguracionDTO getConfiguracion() { return configuracion; }
}