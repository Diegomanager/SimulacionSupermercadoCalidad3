package com.supermercado.presentation.view;

import javax.swing.*;
import java.awt.*;

public class PanelCajas extends JPanel {

    private static final long serialVersionUID = 1L;
    private JPanel[] panelesCajas;
    private JLabel[] lblEstados;
    private JLabel[] lblColas;
    private JLabel[] lblClientes;
    private JLabel[] lblTipos;
    private JProgressBar[] barrasProgreso;
    private int numCajas;

    private static final Color COLOR_VERDE = Theme.STATUS_VERDE;
    private static final Color COLOR_AMARILLO = Theme.STATUS_AMARILLO;
    private static final Color COLOR_NARANJA = Theme.STATUS_NARANJA;
    private static final Color COLOR_ROJO = Theme.STATUS_ROJO;
    private static final Color COLOR_PAUSA = Theme.STATUS_PAUSA;
    private static final Color COLOR_LIBRE = Theme.STATUS_LIBRE;

    public PanelCajas() {
        setLayout(new GridLayout(0, 2, 10, 10));
        setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));
        setBackground(Theme.BACKGROUND);
        inicializarCajas(3);
    }

    public void inicializarCajas(int numCajas) {
        this.numCajas = numCajas;
        this.panelesCajas = new JPanel[numCajas];
        this.lblEstados = new JLabel[numCajas];
        this.lblColas = new JLabel[numCajas];
        this.lblClientes = new JLabel[numCajas];
        this.lblTipos = new JLabel[numCajas];
        this.barrasProgreso = new JProgressBar[numCajas];

        removeAll();

        for (int i = 0; i < numCajas; i++) {
            panelesCajas[i] = crearPanelCaja(i + 1);
            add(panelesCajas[i]);
        }

        revalidate();
        repaint();
    }

    private JPanel crearPanelCaja(int numero) {
        JPanel panel = new JPanel(new BorderLayout(5, 5));
        panel.setBackground(Color.WHITE);
        panel.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(Theme.PRIMARY_BLUE, 2),
            BorderFactory.createEmptyBorder(10, 10, 10, 10)
        ));

        JPanel headerPanel = new JPanel(new BorderLayout());
        headerPanel.setBackground(Theme.PRIMARY_BLUE);
        headerPanel.setBorder(BorderFactory.createEmptyBorder(5, 10, 5, 10));

        JLabel lblNombre = new JLabel("CAJA " + numero);
        lblNombre.setFont(Theme.FONT_HEADER);
        lblNombre.setForeground(Color.WHITE);
        headerPanel.add(lblNombre, BorderLayout.WEST);

        lblTipos[numero - 1] = new JLabel(" NORMAL ");
        lblTipos[numero - 1].setFont(Theme.FONT_SMALL);
        lblTipos[numero - 1].setForeground(Color.WHITE);
        lblTipos[numero - 1].setBackground(COLOR_VERDE);
        lblTipos[numero - 1].setOpaque(true);
        lblTipos[numero - 1].setBorder(BorderFactory.createEmptyBorder(2, 8, 2, 8));
        headerPanel.add(lblTipos[numero - 1], BorderLayout.EAST);

        panel.add(headerPanel, BorderLayout.NORTH);

        JPanel panelInfo = new JPanel(new GridBagLayout());
        panelInfo.setBackground(Color.WHITE);
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.fill = GridBagConstraints.HORIZONTAL;
        gbc.insets = new Insets(3, 5, 3, 5);
        gbc.gridx = 0;
        gbc.gridy = 0;

        lblEstados[numero - 1] = new JLabel("Estado: LIBRE");
        lblEstados[numero - 1].setFont(Theme.FONT_NORMAL);
        panelInfo.add(lblEstados[numero - 1], gbc);
        gbc.gridy++;

        lblColas[numero - 1] = new JLabel("En cola: 0");
        lblColas[numero - 1].setFont(Theme.FONT_NORMAL);
        panelInfo.add(lblColas[numero - 1], gbc);
        gbc.gridy++;

        barrasProgreso[numero - 1] = new JProgressBar(0, 10);
        barrasProgreso[numero - 1].setStringPainted(true);
        barrasProgreso[numero - 1].setFont(Theme.FONT_SMALL);
        barrasProgreso[numero - 1].setBackground(new Color(235, 240, 245));
        barrasProgreso[numero - 1].setString("0 / 10");
        panelInfo.add(barrasProgreso[numero - 1], gbc);
        gbc.gridy++;

        lblClientes[numero - 1] = new JLabel("Atendiendo: -");
        lblClientes[numero - 1].setFont(Theme.FONT_NORMAL);
        lblClientes[numero - 1].setForeground(Color.GRAY);
        panelInfo.add(lblClientes[numero - 1], gbc);

        panel.add(panelInfo, BorderLayout.CENTER);
        return panel;
    }

    public void actualizarCaja(int numCaja, String estado, int cola, String clienteInfo) {
        actualizarCaja(numCaja, estado, cola, clienteInfo, null);
    }

    public void actualizarCaja(int numCaja, String estado, int cola, String clienteInfo, String tipo) {
        if (numCaja > 0 && numCaja <= numCajas) {
            int idx = numCaja - 1;

            lblEstados[idx].setText("Estado: " + estado);
            lblColas[idx].setText("En cola: " + cola);
            lblClientes[idx].setText("Atendiendo: " + (clienteInfo.isEmpty() ? "-" : clienteInfo));

            if (tipo != null) {
                if ("R".equals(tipo)) {
                    lblTipos[idx].setText(" RAPIDA ");
                    lblTipos[idx].setBackground(new Color(241, 196, 15));
                    lblTipos[idx].setForeground(Color.BLACK);
                } else {
                    lblTipos[idx].setText(" NORMAL ");
                    lblTipos[idx].setBackground(COLOR_VERDE);
                    lblTipos[idx].setForeground(Color.WHITE);
                }
            }

            int valorBarra = Math.min(cola, 10);
            barrasProgreso[idx].setValue(valorBarra);
            barrasProgreso[idx].setString(cola + " / 10");

            // ============================================================
            // COLOR DE LA BARRA - CAMBIA SEGUN LA COLA
            // ============================================================
            Color colorBarra;
            
            // Primero verificar si está pausado
            if ("PAUSADA".equals(estado)) {
                colorBarra = COLOR_PAUSA;
            } 
            // Luego según nivel de cola
            else if (cola <= 2) {
                colorBarra = COLOR_VERDE;      // Verde - Poca cola
            } else if (cola <= 4) {
                colorBarra = COLOR_AMARILLO;   // Amarillo - Cola media
            } else if (cola <= 7) {
                colorBarra = COLOR_NARANJA;    // Naranja - Cola alta
            } else {
                colorBarra = COLOR_ROJO;       // Rojo - Cola crítica (>7)
            }
            
            barrasProgreso[idx].setForeground(colorBarra);
            // ============================================================

            // Color del borde y header según estado
            Color borderColor, headerColor;
            if ("ATENDIENDO".equals(estado)) {
                borderColor = COLOR_VERDE;
                headerColor = COLOR_VERDE;
            } else if ("PAUSADA".equals(estado)) {
                borderColor = COLOR_PAUSA;
                headerColor = COLOR_PAUSA;
            } else if (cola > 7) {
                borderColor = COLOR_ROJO;
                headerColor = COLOR_ROJO;
            } else if (cola > 4) {
                borderColor = COLOR_NARANJA;
                headerColor = COLOR_NARANJA;
            } else if (cola > 2) {
                borderColor = COLOR_AMARILLO;
                headerColor = COLOR_AMARILLO;
            } else if (cola > 0) {
                borderColor = COLOR_VERDE;
                headerColor = COLOR_VERDE;
            } else {
                borderColor = COLOR_LIBRE;
                headerColor = COLOR_LIBRE;
            }

            panelesCajas[idx].setBorder(BorderFactory.createCompoundBorder(
                BorderFactory.createLineBorder(borderColor, 3),
                BorderFactory.createEmptyBorder(10, 10, 10, 10)
            ));

            Component[] components = panelesCajas[idx].getComponents();
            for (Component comp : components) {
                if (comp instanceof JPanel) {
                    JPanel header = (JPanel) comp;
                    if (header.getComponentCount() > 1) {
                        header.setBackground(headerColor);
                        break;
                    }
                }
            }

            // Color del texto del estado
            if ("ATENDIENDO".equals(estado)) {
                lblEstados[idx].setForeground(COLOR_VERDE);
            } else if ("PAUSADA".equals(estado)) {
                lblEstados[idx].setForeground(COLOR_PAUSA);
            } else if (cola > 7) {
                lblEstados[idx].setForeground(COLOR_ROJO);
            } else if (cola > 4) {
                lblEstados[idx].setForeground(COLOR_NARANJA);
            } else if (cola > 2) {
                lblEstados[idx].setForeground(COLOR_AMARILLO);
            } else {
                lblEstados[idx].setForeground(Color.BLACK);
            }
        }
    }

    public void reiniciar() {
        for (int i = 0; i < numCajas; i++) {
            actualizarCaja(i + 1, "LIBRE", 0, "");
        }
    }
}